# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare TypeScript files
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary